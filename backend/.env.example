# Copy to .env and adjust. No secrets are committed.
DATABASE_URL=sqlite:///./airbnb.db
SECRET_KEY=change-me-to-a-long-random-string
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_DAYS=7
TAX_RATE=0.06

# CORS: comma-separated frontend origins allowed to call the API.
# Production (Render): set to your Vercel URL, e.g. https://your-app.vercel.app
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
# Vercel preview deployments (changing subdomains) are matched by this regex:
CORS_ORIGIN_REGEX=https://.*\.vercel\.app

# Seed demo data on startup when the DB is empty (useful on ephemeral-disk
# hosts like Render's free tier). Set to "false" to disable.
SEED_ON_START=true
